# Database Configuration
MYSQL_ROOT_PASSWORD=my-secret-pw
MYSQL_DATABASE=db_pasantias

# JWT Configuration (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=myVerySecretKeyForJWTTokenGenerationThatShouldBeLongEnoughAndSecure123456789
JWT_EXPIRATION=3600

# Frontend API URL
VITE_API_URL=http://localhost:8080

# Email (configurar con credenciales reales)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@pasantias.local
VERIFICATION_BASE_URL=http://localhost:8080/auth/confirmar?token=
VERIFICATION_EXPIRATION_HOURS=24

