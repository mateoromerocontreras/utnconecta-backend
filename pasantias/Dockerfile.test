# Build stage
FROM maven:3.9-eclipse-temurin-25 AS build
WORKDIR /app

ARG TEST_DB_URL=jdbc:mysql://host.docker.internal:3306/db_pasantias?useSSL=false&serverTimezone=America/Argentina/Buenos_Aires&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&useUnicode=true
ARG TEST_DB_USERNAME=root
ARG TEST_DB_PASSWORD=my-secret-pw

# Copy pom.xml and download dependencies (layer caching)
COPY pom.xml .
RUN mvn dependency:go-offline -B

# Copy source code and run full verification
COPY src ./src
RUN mvn clean verify -Dspring.profiles.active=test -Dorg.slf4j.simpleLogger.defaultLogLevel=info -Dspring.datasource.url=${TEST_DB_URL} -Dspring.datasource.username=${TEST_DB_USERNAME} -Dspring.datasource.password=${TEST_DB_PASSWORD}

# Runtime stage
FROM eclipse-temurin:25-jre
WORKDIR /app

# Copy jar from build stage
COPY --from=build /app/target/pasantias-0.0.1-SNAPSHOT.jar app.jar

# Expose port
EXPOSE 8080

# Run application
ENTRYPOINT ["java", "-jar", "app.jar"]